{
  "name": "SmartHomeCircle",
  "version": "1.4.0",
  "private": true,
  "scripts": {
    "start": "cross-env SOCKET=true node ./scripts/next-remote-watch.js ./data",
    "dev": "next dev --webpack",
    "build": "next build --webpack && node ./scripts/generate-sitemap.js",
    "export": "npm run build",
    "serve": "npx serve@latest out",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "lint": "eslint --fix pages components lib layouts scripts",
    "prepare": "husky",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@mailchimp/mailchimp_marketing": "^3.0.80",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.25.12",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.2",
    "image-size": "^2.0.2",
    "js-cookie": "^3.0.1",
    "mdx-bundler": "^10.1.1",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "postcss": "^8.4.21",
    "preact": "^10.6.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.3",
    "reading-time": "1.3.0",
    "rehype-autolink-headings": "^6.1.0",
    "rehype-citation": "^0.1.1",
    "rehype-katex": "^6.0.2",
    "rehype-prism-plus": "^1.1.3",
    "rehype-slug": "^5.0.0",
    "remark-footnotes": "^4.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.5",
    "smoothscroll-polyfill": "^0.4.4",
    "tailwindcss": "^4.2.4",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.4",
    "@svgr/webpack": "^8.1.0",
    "cross-env": "^10.1.0",
    "dedent": "^1.7.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "file-loader": "^6.0.0",
    "globby": "^16.2.0",
    "husky": "^9.1.7",
    "inquirer": "^13.4.2",
    "lint-staged": "^16.4.0",
    "next-remote-watch": "^1.0.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "eslint --fix"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "prettier --write"
    ]
  }
}
